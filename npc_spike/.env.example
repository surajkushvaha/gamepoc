# Copy this file to `.env` and fill in your real keys. `.env` is git-ignored.
# You only need ONE working provider, but adding several is the whole point:
# the router falls over to the next one whenever a provider rate-limits or fails.

# --- Provider API keys (set the ones you have; leave the rest blank) --------
CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
# Cloudflare needs BOTH the token and the account id.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Optional: override the failover order -----------------------------------
# Comma-separated "provider:model", tried best-first. Providers whose key is
# missing are skipped automatically. Leave unset to use the built-in default
# (Gemma 4 everywhere it's hosted; Groq holds a Llama fallback since it has no
# Gemma 4):
# NPC_AI_ROUTE=cerebras:gemma-4-31b, nvidia:google/gemma-4-31b-it, openrouter:google/gemma-4-31b-it:free, cloudflare:@cf/google/gemma-4-26b-a4b-it, groq:llama-3.3-70b-versatile
